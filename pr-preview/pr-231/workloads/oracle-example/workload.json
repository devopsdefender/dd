{
  "name": "oracle-example",
  "kind": "oracle",
  "image": "ghcr.io/devopsdefender/oracle-example:latest",
  "expose": [{"label": "api", "port": 8080, "auth": "public"}],
  "env": ["ORACLE_SIGNER_KEY=${ORACLE_SIGNER_KEY}"],
  "kind_config": {
    "kind": "oracle",
    "schedule": "every 60s",
    "signer_env": "ORACLE_SIGNER_KEY",
    "public_log": true
  }
}
