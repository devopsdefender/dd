{
  "name": "openclaw",
  "kind": "bot",
  "image": "ghcr.io/devopsdefender/openclaw:latest",
  "expose": [{"label": "api", "port": 8080, "auth": "owner"}],
  "env": ["SIGNAL_TOKEN=${SIGNAL_TOKEN}"],
  "kind_config": {
    "kind": "bot",
    "wake_schedule": "every 60s",
    "state_volume": "openclaw-state",
    "history": {
      "client_pubkey": "REPLACE_WITH_YOUR_X25519_PUBKEY_BASE64"
    }
  }
}
