{
  "app_name": "bastion",
  "github_release": {
    "repo": "devopsdefender/dd",
    "asset": "bastion.x86_64",
    "rename": "bastion",
    "tag": "${DD_RELEASE_TAG}"
  },
  "inherit_token": true,
  "expose": { "hostname_label": "block", "port": 7681 },
  "cmd": [
    "bastion",
    "serve",
    "--port",
    "7681",
    "--bind",
    "0.0.0.0",
    "--capture-socket",
    "/run/ee/capture.sock",
    "--ee-socket",
    "/var/lib/easyenclave/agent.sock",
    "--cp-url",
    "http://127.0.0.1:8080",
    "--noise-key",
    "/var/lib/easyenclave/bastion/noise-static.key"
  ]
}
