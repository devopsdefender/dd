{
  "app_name": "ee-proxy",
  "github_release": {
    "repo": "devopsdefender/dd",
    "asset": "ee-proxy.x86_64",
    "rename": "ee-proxy",
    "tag": "${DD_RELEASE_TAG}"
  },
  "inherit_token": true,
  "expose": { "hostname_label": "ee", "port": 7682 },
  "cmd": [
    "ee-proxy",
    "--port",
    "7682",
    "--ee-socket",
    "/var/lib/easyenclave/agent.sock",
    "--trust-file",
    "/run/ee-proxy/trusted-devices.json",
    "--key-file",
    "/run/ee-proxy/noise.key"
  ]
}
