# CP (dd-management) local env template.
#
# Usage:
#   envsubst < scripts/envs/cp.env.tmpl > /tmp/cp.env
#   bash scripts/run-local-vm.sh local-cp /tmp/cp.env
#
# Required env vars (export before running envsubst):
#   DD_CF_API_TOKEN      CF API token with tunnel + DNS + Access scopes
#   DD_CF_ACCOUNT_ID     CF account id
#   DD_CF_ZONE_ID        CF zone id for devopsdefender.com
#   DD_ITA_API_KEY       Intel Trust Authority subscription key
#   DD_HOSTNAME          where this CP claims its tunnel (must be a
#                        unique hostname in the CF zone, e.g.
#                        `local-dev-alex.devopsdefender.com`)
#
# Optional:
#   DD_ENV               defaults to "local" — controls tunnel naming
#                        (`dd-{env}-cp-*`) and STONITH scope
#   DD_ACCESS_ADMIN_EMAIL  defaults to posix4e@gmail.com break-glass

EE_OWNER=devopsdefender
EE_CAPTURE_SOCKET=/run/ee/capture.sock
EE_BOOT_WORKLOADS=[{"app_name":"mount-models","cmd":["/bin/busybox","sh","-c","set -e; if [ -b /dev/vdc ]; then mkdir -p /var/lib/easyenclave/ollama; mount -t ext4 /dev/vdc /var/lib/easyenclave/ollama; fi"]},{"app_name":"dd-management","github_release":{"repo":"devopsdefender/dd","asset":"devopsdefender","tag":"latest"},"inherit_token":true,"cmd":["devopsdefender"],"env":["DD_MODE=management","DD_CF_API_TOKEN=${DD_CF_API_TOKEN}","DD_CF_ACCOUNT_ID=${DD_CF_ACCOUNT_ID}","DD_CF_ZONE_ID=${DD_CF_ZONE_ID}","DD_CF_DOMAIN=devopsdefender.com","DD_HOSTNAME=${DD_HOSTNAME}","DD_ENV=${DD_ENV:-local}","DD_OWNER=devopsdefender","DD_ACCESS_ADMIN_EMAIL=${DD_ACCESS_ADMIN_EMAIL:-posix4e@gmail.com}","DD_PORT=8080","DD_ITA_API_KEY=${DD_ITA_API_KEY}","DD_ITA_BASE_URL=https://api.trustauthority.intel.com","DD_ITA_JWKS_URL=https://portal.trustauthority.intel.com/certs","DD_ITA_ISSUER=https://portal.trustauthority.intel.com"]}]
