# Agent (dd-agent) local env template. Registers against an already-
# running CP (local or remote).
#
# Usage:
#   envsubst < scripts/envs/agent.env.tmpl > /tmp/agent.env
#   bash scripts/run-local-vm.sh local-agent-1 /tmp/agent.env
#
# Required env vars:
#   DD_CP_URL            where this agent registers, e.g.
#                        https://local-dev-alex.devopsdefender.com
#                        (the CP's DD_HOSTNAME)
#   DD_ITA_API_KEY       Intel Trust Authority subscription key
#   DD_VM_NAME           agent label as it appears on /api/agents
#                        (e.g. "dd-local-dev-1")
#
# Optional:
#   DD_ENV               defaults to "local"

EE_OWNER=devopsdefender
EE_CAPTURE_SOCKET=/run/ee/capture.sock
EE_BOOT_WORKLOADS=[{"app_name":"mount-models","cmd":["/bin/busybox","sh","-c","set -e; if [ -b /dev/vdc ]; then mkdir -p /var/lib/easyenclave/ollama; mount -t ext4 /dev/vdc /var/lib/easyenclave/ollama; fi"]},{"app_name":"dd-agent","github_release":{"repo":"devopsdefender/dd","asset":"devopsdefender","tag":"latest"},"inherit_token":true,"cmd":["devopsdefender","agent"],"env":["DD_MODE=agent","DD_CP_URL=${DD_CP_URL}","DD_ITA_API_KEY=${DD_ITA_API_KEY}","DD_ITA_BASE_URL=https://api.trustauthority.intel.com","DD_ITA_JWKS_URL=https://portal.trustauthority.intel.com/certs","DD_ITA_ISSUER=https://portal.trustauthority.intel.com","DD_OWNER=devopsdefender","DD_ENV=${DD_ENV:-local}","DD_VM_NAME=${DD_VM_NAME}","DD_PORT=8080"]}]
